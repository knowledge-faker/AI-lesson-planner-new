
.page.data-v-61fb1047 { min-height: 100vh; background-color: #F5F7FA; padding: 20px;
}
.header.data-v-61fb1047 { text-align: center; margin-bottom: 30px;
}
.title.data-v-61fb1047 { font-size: 22px; font-weight: bold; color: #333; margin-bottom: 10px;
}
.subtitle.data-v-61fb1047 { font-size: 14px; color: #666; margin-bottom: 5px;
}
.subtitle-sm.data-v-61fb1047 { font-size: 12px; color: #999;
}
.vip-card.data-v-61fb1047 {
  background: #fff; border-radius: 16px; padding: 30px 20px; margin-bottom: 20px;
  text-align: center; position: relative; border: 1px solid #eee;
}
.vip-card.recommend.data-v-61fb1047 { border: 2px solid #FF6B6B; position: relative;
}
.badge.data-v-61fb1047 {
  position: absolute; top: -10px; right: 20px; background: #FF6B6B; color: #fff;
  padding: 4px 12px; border-radius: 12px; font-size: 12px;
}
.card-title.data-v-61fb1047 { font-size: 18px; font-weight: bold; color: #555; margin-bottom: 10px;
}
.card-price.data-v-61fb1047 { font-size: 32px; font-weight: bold; color: #5C6AC4; margin-bottom: 10px;
}
.card-price.highlight.data-v-61fb1047 { color: #5C6AC4;
}
.days.data-v-61fb1047 { font-size: 14px; color: #999; font-weight: normal;
}
.card-desc.data-v-61fb1047 { font-size: 14px; color: #666; margin-bottom: 20px;
}
.features.data-v-61fb1047 { text-align: left; padding-left: 20px; margin-bottom: 25px;
}
.f-item.data-v-61fb1047 { font-size: 14px; color: #333; margin-bottom: 8px;
}
.buy-btn.data-v-61fb1047 {
  background: #5C6AC4; color: #fff; border-radius: 8px; border: none;
  height: 44px; line-height: 44px; width: 60%; font-size: 16px;
}
.pay-info.data-v-61fb1047 { text-align: center; margin-top: 40px; padding-bottom: 30px;
}
.pay-title.data-v-61fb1047 { font-size: 16px; font-weight: bold; color: #5C6AC4; margin-bottom: 10px;
}
.pay-desc.data-v-61fb1047 { font-size: 12px; color: #666; margin-bottom: 5px;
}
.pay-tip.data-v-61fb1047 { font-size: 10px; color: #999;
}


/* 确保 .page 有底部内边距，防止内容被遮挡 */
.page.data-v-61fb1047 { padding-bottom: 120rpx !important;
}
.footer-tabbar.data-v-61fb1047 {
  position: fixed;
  bottom: 0;
  left: 0;
  width: 100%;
  height: 100rpx;
  background-color: #5C6AC4;
  display: flex;
  justify-content: space-around;
  align-items: center;
  z-index: 999;
}
.tab-item.data-v-61fb1047 {
  color: #FFFFFF;
  font-size: 28rpx;
  flex: 1;
  text-align: center;
  opacity: 0.7;
}
.tab-item.active.data-v-61fb1047 {
  opacity: 1;
  font-weight: bold;
}
